#!/bin/sh
# Reject commit messages that mention AI authorship.
#
# Git for Windows runs extensionless hooks through its bundled POSIX shell,
# so keeping this hook in sh makes it work on both Windows and Unix clones.

if grep -qiE 'co-authored-by.*(claude|anthropic|qwen|alibaba)|co-authored-by.*ai|generated by.*(claude|qwen)|generated with.*(claude|qwen)' "$1"; then
    echo "BLOCKED: commit message contains AI attribution." >&2
    echo "Remove Co-Authored-By / AI mentions and try again." >&2
    exit 1
fi
