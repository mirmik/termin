@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(termin_base REQUIRED)
find_dependency(termin_graphics REQUIRED)
find_dependency(termin_window REQUIRED)
find_dependency(termin_scene REQUIRED)
find_dependency(termin_input REQUIRED)
find_dependency(termin_render REQUIRED)

set(termin_display_HAS_SDL @TERMIN_DISPLAY_HAS_SDL@)
set(termin_display_REQUIRES_SDL2_PACKAGE @TERMIN_DISPLAY_REQUIRES_SDL2_PACKAGE@)
if(termin_display_REQUIRES_SDL2_PACKAGE AND NOT TARGET SDL2::SDL2)
    find_dependency(SDL2 REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/termin_displayTargets.cmake")
