digraph termin_dependencies {
	graph [bgcolor=white,
		nodesep=0.45,
		overlap=false,
		pad=0.2,
		rankdir=LR,
		ranksep=0.9,
		splines=true
	];
	node [color="#444444",
		fillcolor="#f7f7f7",
		fontname="DejaVu Sans",
		fontsize=11,
		margin="0.10,0.06",
		shape=box,
		style="rounded,filled"
	];
	edge [arrowsize=0.7,
		color="#666666",
		penwidth=1.1
	];
	subgraph cluster_foundation {
		graph [color="#d9d9d9",
			label=Foundation,
			style=rounded
		];
		"termin-base";
		"termin-mesh";
		"termin-inspect";
		"termin-scene";
		"termin-input";
		"termin-modules";
		"termin-collision";
		"termin-physics";
		"termin-skeleton";
		"termin-animation";
	}
	subgraph cluster_render {
		graph [color="#d9d9d9",
			label="Render Stack",
			style=rounded
		];
		"termin-graphics";
		"termin-render";
		"termin-display";
		"termin-components-render";
	}
	subgraph cluster_components {
		graph [color="#d9d9d9",
			label="Other Components",
			style=rounded
		];
		"termin-components-collision";
		"termin-components-skeleton";
		"termin-components-animation";
		"termin-components-physics";
		"termin-components-mesh";
		"termin-components-kinematic";
	}
	subgraph cluster_runtime {
		graph [color="#d9d9d9",
			label=Runtime,
			style=rounded
		];
		"termin-engine";
	}
	subgraph cluster_ui {
		graph [color="#d9d9d9",
			label=UI,
			style=rounded
		];
		"termin-gui";
		"termin-nodegraph";
	}
	subgraph cluster_application {
		graph [color="#d9d9d9",
			label=Application,
			style=rounded
		];
		termin;
		"diffusion-editor";
	}
	"termin-csharp";
	"termin-base" -> "termin-mesh";
	"termin-base" -> "termin-inspect";
	"termin-base" -> "termin-modules";
	"termin-base" -> "termin-physics";
	"termin-mesh" -> "termin-graphics";
	"termin-mesh" -> "termin-components-collision";
	"termin-mesh" -> "termin-components-mesh";
	"termin-inspect" -> "termin-scene";
	"termin-scene" -> "termin-input";
	"termin-scene" -> "termin-collision";
	"termin-scene" -> "termin-render";
	"termin-scene" -> "termin-components-mesh";
	"termin-scene" -> "termin-components-kinematic";
	"termin-input" -> "termin-display";
	"termin-collision" -> "termin-engine";
	"termin-collision" -> "termin-components-collision";
	"termin-collision" -> "termin-physics";
	"termin-scene" -> "termin-skeleton";
	"termin-inspect" -> "termin-animation";
	"termin-skeleton" -> "termin-animation";
	"termin-graphics" -> "termin-render";
	"termin-graphics" -> "termin-gui";
	"termin-render" -> "termin-display";
	"termin-display" -> "termin-components-render";
	"termin-physics" -> "termin-components-physics";
	"termin-components-collision" -> "termin-components-physics";
	"termin-skeleton" -> "termin-components-skeleton";
	"termin-animation" -> "termin-components-animation";
	"termin-components-skeleton" -> "termin-components-animation";
	"termin-components-skeleton" -> termin;
	"termin-components-animation" -> termin;
	"termin-components-collision" -> termin;
	"termin-components-kinematic" -> termin;
	"termin-components-render" -> termin;
	"termin-components-physics" -> termin;
	"termin-physics" -> termin;
	"termin-modules" -> termin;
	"termin-engine" -> termin;
	"termin-gui" -> termin;
	"termin-nodegraph" -> termin;
	termin -> "termin-csharp";
	"termin-gui" -> "termin-nodegraph";
	"termin-gui" -> "diffusion-editor";
}
