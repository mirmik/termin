if(NOT TARGET "nanobind::@TERMIN_NANOBIND_RUNTIME_NAME@")
    include(
        "${CMAKE_CURRENT_LIST_DIR}/../termin-nanobind/terminNanobindTargets.cmake"
    )
endif()

# A native library may expose nanobind types in its public C++ API without
# building a Python extension in the current CMake project. In that case the
# imported runtime target is the complete dependency contract and requiring a
# Python development installation would make unrelated C++ consumers fail.
if(NOT TARGET Python::Interpreter OR NOT TARGET Python::Module)
    return()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/../../nanobind/cmake/nanobind-config.cmake")

execute_process(
    COMMAND "${Python_EXECUTABLE}" -I -c
        "import sys, sysconfig; print(f'{sys.version_info.major}.{sys.version_info.minor}|{sysconfig.get_config_var(\"SOABI\") or \"\"}|{int(bool(sysconfig.get_config_var(\"Py_GIL_DISABLED\") or 0))}')"
    OUTPUT_VARIABLE _termin_nanobind_python_abi
    OUTPUT_STRIP_TRAILING_WHITESPACE
    RESULT_VARIABLE _termin_nanobind_python_abi_result
    ERROR_VARIABLE _termin_nanobind_python_abi_error
)
if(NOT _termin_nanobind_python_abi_result EQUAL 0)
    message(FATAL_ERROR
        "Failed to inspect consumer Python ABI for termin-nanobind-sdk: "
        "${_termin_nanobind_python_abi_error}")
endif()
string(REPLACE "|" ";" _termin_nanobind_python_abi_fields
    "${_termin_nanobind_python_abi}")
list(LENGTH _termin_nanobind_python_abi_fields
    _termin_nanobind_python_abi_field_count)
if(NOT _termin_nanobind_python_abi_field_count EQUAL 3)
    message(FATAL_ERROR
        "Malformed consumer Python ABI probe: ${_termin_nanobind_python_abi}")
endif()
list(GET _termin_nanobind_python_abi_fields 0
    _termin_nanobind_python_version)
list(GET _termin_nanobind_python_abi_fields 1
    _termin_nanobind_python_soabi)
list(GET _termin_nanobind_python_abi_fields 2
    _termin_nanobind_python_free_threaded)

set(_termin_nanobind_expected_python_version
    "@Python_VERSION_MAJOR@.@Python_VERSION_MINOR@")
set(_termin_nanobind_expected_python_soabi "@Python_SOABI@")
if(NOT _termin_nanobind_python_version STREQUAL
       _termin_nanobind_expected_python_version
   OR NOT _termin_nanobind_python_soabi STREQUAL
       _termin_nanobind_expected_python_soabi
   OR NOT _termin_nanobind_python_free_threaded STREQUAL "1")
    message(FATAL_ERROR
        "termin-nanobind-sdk Python ABI mismatch: package expects "
        "${_termin_nanobind_expected_python_version}|"
        "${_termin_nanobind_expected_python_soabi}|"
        "1, consumer selected "
        "${_termin_nanobind_python_abi}")
endif()

set(TERMIN_NANOBIND_RUNTIME_TARGET
    "nanobind::@TERMIN_NANOBIND_RUNTIME_NAME@")
include("${CMAKE_CURRENT_LIST_DIR}/termin-nanobind-profile.cmake")

function(nanobind_build_library target_name)
    if(TARGET "${target_name}")
        return()
    endif()
    message(FATAL_ERROR
        "termin-nanobind-sdk owns the shared nanobind runtime "
        "'${TERMIN_NANOBIND_RUNTIME_TARGET}'. Consumers must use "
        "nanobind_add_module(... NB_SHARED ...) and cannot build "
        "an additional runtime '${target_name}'.")
endfunction()
