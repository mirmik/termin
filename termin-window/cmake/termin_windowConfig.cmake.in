@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(termin_base REQUIRED)
find_dependency(termin_graphics REQUIRED)

set(termin_window_HAS_SDL @TERMIN_WINDOW_HAS_SDL@)
set(termin_window_REQUIRES_SDL2_PACKAGE @TERMIN_WINDOW_REQUIRES_SDL2_PACKAGE@)
if(termin_window_REQUIRES_SDL2_PACKAGE AND NOT TARGET SDL2::SDL2)
    find_dependency(SDL2 REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/termin_windowTargets.cmake")

check_required_components(termin_window)
