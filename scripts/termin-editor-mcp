#!/usr/bin/env python3
"""CLI client and stdio MCP broker for a running Termin editor."""

from __future__ import annotations

import argparse
import json
import sys
import tempfile
import urllib.error
import urllib.request
from pathlib import Path
from typing import Any


DEFAULT_SESSION_FILE = Path(tempfile.gettempdir()) / "termin-editor-mcp.json"
SUPPORTED_PROTOCOL_VERSIONS = (
    "2025-11-25",
    "2025-06-18",
    "2025-03-26",
    "2024-11-05",
)
LATEST_PROTOCOL_VERSION = SUPPORTED_PROTOCOL_VERSIONS[0]


class EditorMcpClientError(RuntimeError):
    """Failure while discovering or calling the private editor endpoint."""


def _load_session(path: Path) -> dict[str, Any]:
    try:
        session = json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        raise EditorMcpClientError(
            f"Session file not found: {path}\n"
            "Start the editor with TERMIN_EDITOR_MCP=1."
        ) from None
    except json.JSONDecodeError as exc:
        raise EditorMcpClientError(f"Invalid session file '{path}': {exc}") from exc
    except OSError as exc:
        raise EditorMcpClientError(f"Cannot read session file '{path}': {exc}") from exc

    if not isinstance(session, dict):
        raise EditorMcpClientError(f"Invalid session file '{path}': root must be an object")
    url = session.get("url")
    token = session.get("token")
    if not isinstance(url, str) or not url:
        raise EditorMcpClientError(f"Invalid session file '{path}': missing endpoint URL")
    if not isinstance(token, str) or not token:
        raise EditorMcpClientError(f"Invalid session file '{path}': missing bearer token")
    return session


def _post_rpc(session: dict[str, Any], payload: object) -> object | None:
    data = json.dumps(payload).encode("utf-8")
    request = urllib.request.Request(
        session["url"],
        data=data,
        headers={
            "Content-Type": "application/json",
            "Accept": "application/json",
            "Authorization": f"Bearer {session['token']}",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(request, timeout=35) as response:
            body = response.read()
            if response.status == 204 or not body:
                return None
            return json.loads(body.decode("utf-8"))
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        raise EditorMcpClientError(f"Editor endpoint returned HTTP {exc.code}: {body}") from exc
    except urllib.error.URLError as exc:
        raise EditorMcpClientError(f"Cannot reach editor MCP endpoint: {exc}") from exc
    except (UnicodeDecodeError, json.JSONDecodeError) as exc:
        raise EditorMcpClientError(f"Editor endpoint returned invalid JSON: {exc}") from exc


def _call(session: dict[str, Any], method: str, params: object | None = None) -> dict[str, Any]:
    payload: dict[str, Any] = {
        "jsonrpc": "2.0",
        "id": 1,
        "method": method,
    }
    if params is not None:
        payload["params"] = params
    response = _post_rpc(session, payload)
    if not isinstance(response, dict):
        raise EditorMcpClientError("Editor endpoint returned no JSON-RPC response")
    return response


def _rpc_result(request_id: object, result: object) -> dict[str, object]:
    return {"jsonrpc": "2.0", "id": request_id, "result": result}


def _rpc_error(
    request_id: object,
    code: int,
    message: str,
    *,
    data: object | None = None,
) -> dict[str, object]:
    error: dict[str, object] = {"code": code, "message": message}
    if data is not None:
        error["data"] = data
    return {"jsonrpc": "2.0", "id": request_id, "error": error}


class EditorMcpStdioBroker:
    """Standard MCP lifecycle in front of the editor's private HTTP endpoint."""

    def __init__(self, session_file: Path) -> None:
        self._session_file = session_file
        self._initialized = False
        self._client_ready = False

    def handle(self, request: object) -> dict[str, object] | None:
        if not isinstance(request, dict) or request.get("jsonrpc") != "2.0":
            return _rpc_error(None, -32600, "Invalid Request")
        method = request.get("method")
        if not isinstance(method, str) or not method:
            return _rpc_error(None, -32600, "Invalid Request")

        is_notification = "id" not in request
        request_id = request.get("id")
        if not is_notification and (
            isinstance(request_id, bool)
            or not isinstance(request_id, (str, int, float, type(None)))
        ):
            return _rpc_error(None, -32600, "Invalid Request")

        if method == "initialize":
            response = self._initialize(request_id, request.get("params"))
        elif method == "notifications/initialized":
            if self._initialized:
                self._client_ready = True
            response = None
        elif method == "ping":
            response = _rpc_result(request_id, {})
        elif not self._initialized or not self._client_ready:
            response = _rpc_error(request_id, -32002, "Server not initialized")
        elif method in ("tools/list", "tools/call"):
            response = self._proxy(request, request_id, is_notification=is_notification)
        else:
            response = _rpc_error(request_id, -32601, f"Method not found: {method}")

        return None if is_notification else response

    def _initialize(self, request_id: object, params: object) -> dict[str, object]:
        if self._initialized:
            return _rpc_error(request_id, -32600, "Server is already initialized")
        if not isinstance(params, dict):
            return _rpc_error(request_id, -32602, "Invalid initialize params")
        requested_version = params.get("protocolVersion")
        if not isinstance(requested_version, str) or not requested_version:
            return _rpc_error(request_id, -32602, "Missing protocolVersion")

        protocol_version = (
            requested_version
            if requested_version in SUPPORTED_PROTOCOL_VERSIONS
            else LATEST_PROTOCOL_VERSION
        )
        self._initialized = True
        return _rpc_result(
            request_id,
            {
                "protocolVersion": protocol_version,
                "capabilities": {"tools": {"listChanged": False}},
                "serverInfo": {
                    "name": "termin-editor",
                    "version": "0.1.0",
                },
                "instructions": (
                    "Tools control the Termin Editor identified by the configured "
                    "session file. Start the editor with TERMIN_EDITOR_MCP=1."
                ),
            },
        )

    def _proxy(
        self,
        request: dict[str, object],
        request_id: object,
        *,
        is_notification: bool,
    ) -> dict[str, object] | None:
        try:
            session = _load_session(self._session_file)
            response = _post_rpc(session, request)
        except EditorMcpClientError as exc:
            print(f"termin-editor-mcp: {exc}", file=sys.stderr, flush=True)
            if is_notification:
                return None
            return _rpc_error(
                request_id,
                -32050,
                "Termin Editor is unavailable",
                data={
                    "sessionFile": str(self._session_file),
                    "detail": str(exc),
                },
            )

        if response is None:
            return None
        if not isinstance(response, dict):
            return _rpc_error(request_id, -32603, "Editor returned an invalid response")
        return response


def _serve_stdio(session_file: Path) -> int:
    broker = EditorMcpStdioBroker(session_file)
    for line in sys.stdin:
        try:
            request = json.loads(line)
        except json.JSONDecodeError as exc:
            print(f"termin-editor-mcp: invalid JSON input: {exc}", file=sys.stderr, flush=True)
            response: object | None = _rpc_error(None, -32700, "Parse error")
        else:
            if isinstance(request, list):
                response = _rpc_error(None, -32600, "JSON-RPC batches are not supported")
            else:
                response = broker.handle(request)
        if response is not None:
            print(json.dumps(response, ensure_ascii=False, separators=(",", ":")), flush=True)
    return 0


def _print_response(response: dict[str, Any]) -> int:
    if "error" in response:
        print(json.dumps(response["error"], indent=2, ensure_ascii=False), file=sys.stderr)
        return 1

    result = response.get("result")
    if isinstance(result, dict) and "content" in result:
        for item in result.get("content", []):
            if isinstance(item, dict) and item.get("type") == "text":
                print(item.get("text", ""), end="")
        if result.get("isError"):
            return 1
        return 0

    if isinstance(result, dict) and set(result.keys()) <= {"ok", "output", "error", "wants_more"}:
        print(str(result.get("output", "")), end="")
        if not result.get("ok", False):
            error = result.get("error")
            if error:
                print(error, file=sys.stderr)
            return 1
        return 0

    print(json.dumps(result, indent=2, ensure_ascii=False))
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--session",
        type=Path,
        default=DEFAULT_SESSION_FILE,
        help=f"Editor MCP session file. Default: {DEFAULT_SESSION_FILE}",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    sub.add_parser("serve", help="Serve standard MCP over stdin/stdout")
    sub.add_parser("initialize")
    sub.add_parser("tools-list")

    exec_parser = sub.add_parser("exec")
    exec_parser.add_argument("script")
    exec_parser.add_argument("--timeout", type=float, default=30.0)

    exec_file_parser = sub.add_parser("exec-file")
    exec_file_parser.add_argument("path", type=Path)
    exec_file_parser.add_argument("--timeout", type=float, default=30.0)

    screenshot_parser = sub.add_parser("screenshot")
    screenshot_parser.add_argument("--path", default=None)
    screenshot_parser.add_argument("--include-image", action="store_true")
    screenshot_parser.add_argument("--timeout", type=float, default=30.0)

    framegraph_parser = sub.add_parser("framegraph")
    framegraph_parser.add_argument("--target-index", type=int, default=None)
    framegraph_parser.add_argument("--include-pass-json", action="store_true")
    framegraph_parser.add_argument("--include-debugger-pass", action="store_true")
    framegraph_parser.add_argument("--timeout", type=float, default=30.0)

    framegraph_capture_parser = sub.add_parser("framegraph-capture")
    framegraph_capture_parser.add_argument("--target-index", type=int, default=None)
    framegraph_capture_parser.add_argument("--resource", default=None)
    framegraph_capture_parser.add_argument("--path", default=None)
    framegraph_capture_parser.add_argument("--include-image", action="store_true")
    framegraph_capture_parser.add_argument("--capture-kind", default="main")
    framegraph_capture_parser.add_argument("--channel-mode", type=int, default=0)
    framegraph_capture_parser.add_argument("--highlight-hdr", action="store_true")
    framegraph_capture_parser.add_argument("--timeout", type=float, default=30.0)

    framegraph_pass_capture_parser = sub.add_parser("framegraph-pass-capture")
    framegraph_pass_capture_parser.add_argument("--target-index", type=int, default=None)
    framegraph_pass_capture_parser.add_argument("--pass-index", type=int, default=None)
    framegraph_pass_capture_parser.add_argument("--pass-name", default=None)
    framegraph_pass_capture_parser.add_argument("--symbol", default=None)
    framegraph_pass_capture_parser.add_argument("--symbol-index", type=int, default=None)
    framegraph_pass_capture_parser.add_argument("--path", default=None)
    framegraph_pass_capture_parser.add_argument("--include-image", action="store_true")
    framegraph_pass_capture_parser.add_argument("--capture-kind", default="main")
    framegraph_pass_capture_parser.add_argument("--timeout", type=float, default=30.0)

    args = parser.parse_args()

    if args.command == "serve":
        return _serve_stdio(args.session)

    try:
        session = _load_session(args.session)
    except EditorMcpClientError as exc:
        parser.exit(1, f"termin-editor-mcp: {exc}\n")

    if args.command == "initialize":
        response = _call(
            session,
            "initialize",
            {
                "protocolVersion": "2024-11-05",
                "capabilities": {},
                "clientInfo": {"name": "termin-editor-mcp-cli", "version": "0.1.0"},
            },
        )
    elif args.command == "tools-list":
        response = _call(session, "tools/list")
    elif args.command == "exec":
        response = _call(
            session,
            "tools/call",
            {
                "name": "execute_python_script",
                "arguments": {"script": args.script, "timeout": args.timeout},
            },
        )
    elif args.command == "exec-file":
        script = args.path.read_text(encoding="utf-8")
        response = _call(
            session,
            "tools/call",
            {
                "name": "execute_python_script",
                "arguments": {"script": script, "timeout": args.timeout},
            },
        )
    elif args.command == "screenshot":
        arguments: dict[str, Any] = {
            "include_image": args.include_image,
            "timeout": args.timeout,
        }
        if args.path is not None:
            arguments["path"] = args.path
        response = _call(
            session,
            "tools/call",
            {
                "name": "capture_editor_screenshot",
                "arguments": arguments,
            },
        )
    elif args.command == "framegraph":
        arguments = {
            "include_pass_json": args.include_pass_json,
            "include_debugger_pass": args.include_debugger_pass,
            "timeout": args.timeout,
        }
        if args.target_index is not None:
            arguments["target_index"] = args.target_index
        response = _call(
            session,
            "tools/call",
            {
                "name": "inspect_framegraph",
                "arguments": arguments,
            },
        )
    elif args.command == "framegraph-capture":
        arguments = {
            "include_image": args.include_image,
            "capture_kind": args.capture_kind,
            "channel_mode": args.channel_mode,
            "highlight_hdr": args.highlight_hdr,
            "timeout": args.timeout,
        }
        if args.target_index is not None:
            arguments["target_index"] = args.target_index
        if args.resource is not None:
            arguments["resource"] = args.resource
        if args.path is not None:
            arguments["path"] = args.path
        response = _call(
            session,
            "tools/call",
            {
                "name": "capture_framegraph_resource",
                "arguments": arguments,
            },
        )
    elif args.command == "framegraph-pass-capture":
        arguments = {
            "include_image": args.include_image,
            "capture_kind": args.capture_kind,
            "timeout": args.timeout,
        }
        if args.target_index is not None:
            arguments["target_index"] = args.target_index
        if args.pass_index is not None:
            arguments["pass_index"] = args.pass_index
        if args.pass_name is not None:
            arguments["pass_name"] = args.pass_name
        if args.symbol is not None:
            arguments["symbol"] = args.symbol
        if args.symbol_index is not None:
            arguments["symbol_index"] = args.symbol_index
        if args.path is not None:
            arguments["path"] = args.path
        response = _call(
            session,
            "tools/call",
            {
                "name": "capture_framegraph_pass_symbol",
                "arguments": arguments,
            },
        )
    else:
        raise AssertionError(args.command)

    return _print_response(response)


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except EditorMcpClientError as exc:
        print(f"termin-editor-mcp: {exc}", file=sys.stderr)
        raise SystemExit(1) from exc
