#!/usr/bin/env python3
import argparse
import json
import os
import sys

from kanboard_client import DEFAULT_ENV_PATH, KanboardError, load_config, parse_params, call_kanboard, redact


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        description="Call the Termin Kanboard JSON-RPC API using ~/.config/termin/kanboard-codex.env.",
    )
    parser.add_argument("method", help="Kanboard JSON-RPC method name, e.g. getMyProjects")
    parser.add_argument(
        "params",
        nargs="?",
        help='Optional JSON params, e.g. \'{"project_id":1,"status_id":1}\'',
    )
    parser.add_argument(
        "--env-file",
        default=os.environ.get("KANBOARD_ENV", DEFAULT_ENV_PATH),
        help=f"Path to env file, default: {DEFAULT_ENV_PATH}",
    )
    parser.add_argument("--id", type=int, default=1, help="JSON-RPC request id")
    parser.add_argument("--compact", action="store_true", help="Print compact JSON")
    parser.add_argument(
        "--raw",
        action="store_true",
        help="Do not redact sensitive-looking response fields. Use only when needed.",
    )
    args = parser.parse_args(argv)

    try:
        config = load_config(args.env_file)
        params = parse_params(args.params)
        response = call_kanboard(config.url, config.user, config.token, args.method, params, args.id)
        output = response if args.raw else redact(response)
        if args.compact:
            print(json.dumps(output, ensure_ascii=False, separators=(",", ":")))
        else:
            print(json.dumps(output, ensure_ascii=False, indent=2))
    except KanboardError as exc:
        print(f"kanboard-api: {exc}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
